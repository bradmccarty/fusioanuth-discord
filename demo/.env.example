# FusionAuth × Discord Demo — Environment Variables
# Copy this to .env and fill in your values.
#
# DISCORD_CLIENT_ID and DISCORD_CLIENT_SECRET come from:
#   https://discord.com/developers/applications → Your App → OAuth2 → General

# ── FusionAuth API key ────────────────────────────────────────────────────
# Create this in the FusionAuth admin UI after first boot:
#   Settings → API Keys → Add → enable Identity Providers + Lambdas (or superuser)
FA_API_KEY=

# ── Discord OAuth2 credentials ────────────────────────────────────────────
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ── Postgres (safe defaults for local dev) ────────────────────────────────
POSTGRES_USER=fusionauth
POSTGRES_PASSWORD=fusionauth_dev
