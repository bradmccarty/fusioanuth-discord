# FusionAuth × Discord Demo — Environment Variables
# Copy this to .env and fill in your Discord credentials.
#
# DISCORD_CLIENT_ID and DISCORD_CLIENT_SECRET come from:
#   https://discord.com/developers/applications → Your App → OAuth2 → General
#
# The POSTGRES values are fine as-is for local demo use.

# ── FusionAuth admin credentials (REQUIRED) ───────────────────────────────
FA_ADMIN_EMAIL=<>
FA_ADMIN_PASSWORD=<>                 # use a strong password — this is your admin account

# ── FusionAuth API key (REQUIRED) ─────────────────────────────────────────
# Must be a valid UUID. This key is created by Kickstart on first boot and
# used by setup.js to provision the Discord IdP and lambda.
# Generate one with: node -e "import('crypto').then(c => console.log(c.randomUUID()))"
FA_API_KEY=<>

# ── Discord OAuth2 credentials (REQUIRED) ─────────────────────────────────
DISCORD_CLIENT_ID=<>
DISCORD_CLIENT_SECRET=<>

# ── Demo application UUID (fixed — matches kickstart.json) ───────────────
FA_APP_ID==

# ── Pre-defined Identity Provider UUID (RECOMMENDED) ──────────────────────
# Set this before running the setup script so you can configure the Discord
# redirect URI in advance. Generate any valid UUID — e.g.:
#   node -e "import('crypto').then(c => console.log(c.randomUUID()))"
# Then add this redirect URI to Discord Developer Portal before running setup:
#   http://localhost:9011/oauth2/callback/e22953ed-041d-4915-bb7b-e6b1164a37a1
FA_IDP_ID=

# ── Postgres (safe defaults for local dev) ────────────────────────────────
POSTGRES_USER=
POSTGRES_PASSWORD=
